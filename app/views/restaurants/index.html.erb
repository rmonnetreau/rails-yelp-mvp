<div class="row">
  <h1 class="card-title">All restaurants</h1>
  <% @restaurants.each do |restaurant| %>
    <div class="col-md-4 mb-4">
      <div class="card h-100">
        <div class="card-body">
          <h5 class="card-title"><%= link_to restaurant.name, restaurant_path(restaurant) %></h5>
          <p class="card-text"><%= restaurant.category.capitalize %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>
<div class="row">
  <div class="col-md-6">
    <div class="card mb-4">
      <div class="card-body">
        <h2 class="card-title">Our top 5 restaurants</h2>
        <ul>
          <% @restaurants.top(5).each do |restaurant| %>
            <li>
              <%= link_to restaurant.name, restaurant_path(restaurant) %>
              - Average rating: <%= restaurant.average_rating %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</div>
