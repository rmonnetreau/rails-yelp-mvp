<div class="d-flex flex-column justify-content-between align-items-center mb-3">
  <%= simple_form_for [@restaurant, @review] do |f| %>
    <%= f.input :content, label: 'Review content', error: 'Content is mandatory, please specify one' %>
    <%= f.input :rating, label: 'Rating', collection: 1..5, error: 'Rating is mandatory, please specify one' %>
    <%= f.submit class: "btn btn-primary" %>
  <% end %>
  <%= link_to "Back to restaurant details", restaurant_path(@restaurant), class: "btn btn-secondary mt-4" %>
</div>
