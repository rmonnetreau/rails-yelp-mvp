<div class="d-flex flex-column justify-content-between align-items-center mb-3">
  <h1><%= @restaurant.name %></h1>
  <p><%= @restaurant.address %></p>
  <p><%= @restaurant.phone_number %></p>
  <p><%= @restaurant.category.capitalize %></p>
  <p>Average rating: <%= @restaurant.average_rating %> / 5</p>
  <ul class="list-unstyled d-grid gap-3">
    <% @restaurant.reviews.each do |review| %>
      <li>
        <div class="card mb-2">
          <div class="card-body">
             <p class="card-text"><%= review.content %></p>
             <p class="card-text"><strong><%= review.rating %> / 5</strong></p>
          </div>
        </div>
      </li>
    <% end %>
  </ul>
  <div class="d-flex justify-content-between align-items-center gap-3 mt-4">
     <%= link_to "Add review", new_restaurant_review_path(@restaurant), class: "btn btn-primary mt-4" %>
     <%= link_to "Edit restaurant", edit_restaurant_path(@restaurant), class: "btn btn-success mt-4" %>
     <%= link_to "Delete restaurant", restaurant_path(@restaurant), class: "btn btn-danger mt-4", data: {turbo_method: :delete, turbo_confirm: "Are you sure?"} %>
     <%= link_to "Back to restaurants list", restaurants_path, class: "btn btn-secondary mt-4" %>
  </div>
</div>
